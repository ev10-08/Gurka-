void displayHand (vector<int>& hand) { //displays all cards in hand using ASCII art
    if (hand.size() == 0) {
        cout << "No cards in hand." << endl;
        return;
    }
    for (int c = 0; c < hand.size(); c++) {
        int val = getCardValue(hand[c]);
        string suitLetter = getCardSuitLetter(hand[c]);
        string topVal, botVal;
        if (val == 10) {
            topVal = "10";
            botVal = "10";
        } else {
            if (val == 11) {
                topVal = "J ";
                botVal = " J";
            } else {
                if (val == 12) {
                    topVal = "Q ";
                    botVal = " Q";
                } else {
                    if (val == 13) {
                        topVal = "K ";
                        botVal = " K";
                    } else {
                        if (val == 14) {
                            topVal = "A ";
                            botVal = " A";
                        } else {
                            topVal = to_string(val) + " ";
                            botVal = " " + to_string(val);
                        }
                    }
                }
            }
        }
        cout << "   Card " << (c + 1) << ":" << endl;
        cout << "   +-----+" << endl;
        cout << "   |" << topVal << "   |" << endl;
        cout << "   |  " << suitLetter << "  |" << endl;
        cout << "   |   " << botVal << "|" << endl;
        cout << "   +-----+" << endl;
        cout << endl;
    }
}

