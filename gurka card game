int main()
{
    int programCompletion = 0;
    srand(static_cast<unsigned int>(time(0)));
    displayIntro();

    while (programCompletion != 2) { //loops as long as user wants to keep playing
        vector<int> player1Hand;
        vector<int> player2Hand;
        vector<int> player3Hand;
        vector<int> deck;
        int scores[3] = {0, 0, 0};
        bool active[3] = {true, true, true};
        int roundNumber = 0, activePlayers = 3;

        while (activePlayers > 1) { //loops until only one player remains
            roundNumber++;
            activePlayers = countActivePlayers(active);
            if (activePlayers <= 1) {
                break;
            }

            displayRoundHeader(roundNumber);
            displayScores(scores, active);

            initializeDeck(deck);
            shuffleDeck(deck);

            player1Hand.clear();
            player2Hand.clear();
            player3Hand.clear();

            int deckIndex = 0;
            for (int i = 0; i < 6; i++) {
                if (active[0]) {
                    dealCards(deck, player1Hand, 1, deckIndex);
                }
                if (active[1]) {
                    dealCards(deck, player2Hand, 1, deckIndex);
                }
                if (active[2]) {
                    dealCards(deck, player3Hand, 1, deckIndex);
                }
            }

            sortHand(player1Hand);
            sortHand(player2Hand);
            sortHand(player3Hand);
            cout << "\nCards have been dealt!\n" << endl;

            int currentLeader = 0;
            if (!active[0]) {
                if (active[1]) {
                    currentLeader = 1;
                } else {
                    currentLeader = 2;
                }
            }

            for (int trick = 0; trick < 6; trick++) {
                bool isLastTrick = (trick == 4);
                displayTrickHeader(trick + 1, isLastTrick);

                int highestValue = -1;
                int trickWinner = -1;
                int cardsPlayed[3] = {-1, -1, -1};

                vector<int> playOrder;
                buildPlayOrder(playOrder, active, currentLeader);

                for (int turn = 0; turn < playOrder.size(); turn++) {
                    int current = playOrder[turn];
                    int playedCard = -1;

                    if (current == 0) {
                        humanTurn(player1Hand, playedCard, highestValue);
                        cardsPlayed[0] = playedCard;
                    } else {
                        if (current == 1) {
                            botTurn(player2Hand, playedCard, highestValue, "Bot 1");
                            cardsPlayed[1] = playedCard;
                        } else {
                            botTurn(player3Hand, playedCard, highestValue, "Bot 2");
                            cardsPlayed[2] = playedCard;
                        }
                    }

                    if (playedCard != -1) {
                        int cardVal = getCardValue(playedCard);
                        int suit = getCardSuit(playedCard);
                        string valStr = getValueString(cardVal);
                        string suitStr = getSuitString(suit);
                        string name = getPlayerName(current);
                        displayCardPlayed(name, valStr, suitStr);

                        //show the played card
                        displayPlayedCard(playedCard);

                        if (cardVal >= highestValue) {
                            highestValue = cardVal;
                            trickWinner = current;
                        }
                    }
                }

                string winnerName = getPlayerName(trickWinner);
                displayTrickWinner(winnerName);
                currentLeader = trickWinner;

                //pause between tricks so the player can see what happened
                if (!isLastTrick) {
                    int nextTrick = 0;
                    cout << "Enter 1 for next trick: ";
                    cin >> nextTrick;
                    while (!cin or nextTrick != 1) { //invalid input/fail check for next trick
                        cout << "Invalid Input. Enter 1 for next trick: ";
                        cin.clear();
                        cin.ignore(10000, '\n');
                        cin >> nextTrick;
                    }
                    cin.ignore(10000, '\n');
                }

                if (isLastTrick) {
                    displayPenaltyHeader();
                    int lastHighest = findHighestCardValue(cardsPlayed);

                    int penalties[3] = {0, 0, 0};
                    for (int i = 0; i < 3; i++) {
                        if (cardsPlayed[i] != -1) {
                            penalties[i] = calculatePenalty(cardsPlayed[i], lastHighest);
                            scores[i] = scores[i] + penalties[i];
                        }
                    }

                    displayPenaltyPoints(penalties, active);
                    checkElimination(scores[0], active[0], "You");
                    checkElimination(scores[1], active[1], "Bot 1");
                    checkElimination(scores[2], active[2], "Bot 2");
                }
            }

            activePlayers = countActivePlayers(active);
            if (activePlayers > 1) {
                int nextRound = 0;
                cout << "\nEnter 1 to continue to next round: ";
                cin >> nextRound;
                while (!cin or nextRound != 1) { //invalid input/fail check for next round
                    cout << "Invalid Input. Enter 1 to continue to next round: ";
                    cin.clear();
                    cin.ignore(10000, '\n');
                    cin >> nextRound;
                }
                cin.ignore(10000, '\n');
            }
        }

        displayGameOver(scores, active);
        programCheck(programCompletion);
    }
}

