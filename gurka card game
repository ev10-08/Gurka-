void humanTurn (vector<int>& hand, int& playedCard, int highestValue) { //handles the human player's turn with input validation
    cout << "\n>>> YOUR TURN <<<\n" << endl;
    if (highestValue >= 0) {
        cout << "Highest card played so far: " << highestValue << endl;
    }
    cout << "\nYour hand:" << endl;
    displayHand(hand);

    int validCards = hand.size();
    int lowestIndex = findLowestCard(hand);
    int beatingIndex = findLowestBeating(hand, highestValue);
    bool canBeat = canPlayerBeat(hand, highestValue);
    int choice = 0;
    bool validChoice = false;

    while (!validChoice) {
        cout << "\nEnter card number to play (1-" << validCards << "): ";
        cin >> choice;
        while (!cin or choice < 1 or choice > validCards) { //invalid input/fail check for card selection
            cout << "Invalid input. Enter card number (1-" << validCards << "): ";
            cin.clear();
            cin.ignore(10000, '\n');
            cin >> choice;
        }

        int selectedIndex = choice - 1;
        int selectedValue = getCardValue(hand[selectedIndex]);

        if (highestValue < 0) {
            validChoice = true;
        } else {
            if (canBeat) {
                if (selectedValue >= highestValue) {
                    validChoice = true;
                } else {
                    cout << "Invalid! You have a card that can beat " << highestValue;
                    cout << ", so you must play it." << endl;
                }
            } else {
                if (selectedIndex == lowestIndex) {
                    validChoice = true;
                } else {
                    cout << "Invalid! You cannot beat " << highestValue;
                    cout << ", so you must play your lowest card." << endl;
                }
            }
        }
    }

    int selectedIndex = choice - 1;
    playedCard = hand[selectedIndex];
    removeCardFromHand(hand, selectedIndex);
    cin.ignore(10000, '\n');
}

void botTurn (vector<int>& hand, int& playedCard, int highestValue, string botName) { //handles bot player's turn with simple AI
    int lowestIndex = findLowestCard(hand);
    int beatingIndex = findLowestBeating(hand, highestValue);
    int chosenIndex = -1;

    if (highestValue < 0) {
        chosenIndex = rand() % hand.size();
    } else {
        if (beatingIndex != -1) {
            chosenIndex = beatingIndex;
        } else {
            chosenIndex = lowestIndex;
        }
    }

    playedCard = hand[chosenIndex];
    removeCardFromHand(hand, chosenIndex);
}

void initializeDeck (vector<int>& deck) { //creates a deck of 52 cards
    deck.clear();
    for (int i = 0; i < 52; i++) {
        deck.push_back(i);
    }
}

void shuffleDeck (vector<int>& deck) { //shuffles the deck using Fisher-Yates algorithm
    for (int i = 51; i > 0; i--) {
        int j = rand() % (i + 1);
        int temp = deck[i];
        deck[i] = deck[j];
        deck[j] = temp;
    }
}

void dealCards (vector<int>& deck, vector<int>& hand, int numCards, int& deckIndex) { //deals cards from deck to a hand
    for (int i = 0; i < numCards; i++) {
        hand.push_back(deck[deckIndex]);
        deckIndex++;
    }
}

void sortHand (vector<int>& hand) { //sorts the hand from lowest to highest card value using bubble sort
    if (hand.size() <= 1) {
        return;
    }
    for (int i = 0; i < hand.size() - 1; i++) {
        for (int j = 0; j < hand.size() - i - 1; j++) {
            if (getCardValue(hand[j]) > getCardValue(hand[j + 1])) {
                int temp = hand[j];
                hand[j] = hand[j + 1];
                hand[j + 1] = temp;
            }
        }
    }
}

void removeCardFromHand (vector<int>& hand, int index) { //removes a card from hand at given index
    hand.erase(hand.begin() + index);
}

void checkElimination (int& score, bool& isActive, string name) { //checks if a player should be eliminated at 30+ points
    if (isActive and score >= 30) {
        isActive = false;
        cout << "\n" << name << " reached " << score << " points - ELIMINATED!" << endl;
    }
}

void buildPlayOrder (vector<int>& playOrder, bool active[], int currentLeader) { //builds the play order starting from the leader
    playOrder.clear();
    for (int p = currentLeader; p < 3; p++) {
        if (active[p]) {
            playOrder.push_back(p);
        }
    }
    for (int p = 0; p < currentLeader; p++) {
        if (active[p]) {
            playOrder.push_back(p);
        }
    }
}

