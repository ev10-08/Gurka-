int getCardValue (int card) { //returns the numeric value of a card from 2 to 14
    return (card % 13) + 2;
}

int getCardSuit (int card) { //returns the suit of a card (0-3)
    return card / 13;
}

string getCardSuitLetter (int card) { //returns the suit as a single letter
    int suit = card / 13;
    if (suit == 0) {
        return "H";
    } else {
        if (suit == 1) {
            return "D";
        } else {
            if (suit == 2) {
                return "S";
            } else {
                return "C";
            }
        }
    }
}

string getValueString (int cardValue) { //converts a card value to its display name
    if (cardValue == 11) {
        return "Jack";
    } else {
        if (cardValue == 12) {
            return "Queen";
        } else {
            if (cardValue == 13) {
                return "King";
            } else {
                if (cardValue == 14) {
                    return "Ace";
                } else {
                    return to_string(cardValue);
                }
            }
        }
    }
}

string getSuitString (int suit) { //converts a suit number to its full name
    if (suit == 0) {
        return "Hearts";
    } else {
        if (suit == 1) {
            return "Diamonds";
        } else {
            if (suit == 2) {
                return "Spades";
            } else {
                return "Clubs";
            }
        }
    }
}

string getPlayerName (int playerIndex) { //returns player name based on index
    if (playerIndex == 0) {
        return "You";
    } else {
        if (playerIndex == 1) {
            return "Bot 1";
        } else {
            return "Bot 2";
        }
    }
}

