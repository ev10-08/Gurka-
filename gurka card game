int findLowestCard (vector<int>& hand) { //finds the index of the lowest valued card in hand
    int lowestValue = 100, lowestIndex = -1;
    for (int i = 0; i < hand.size(); i++) {
        int val = getCardValue(hand[i]);
        if (val < lowestValue) {
            lowestValue = val;
            lowestIndex = i;
        }
    }
    return lowestIndex;
}

int findLowestBeating (vector<int>& hand, int highestValue) { //finds lowest card that can beat the current highest
    int lowestBeatingValue = 100, lowestBeatingIndex = -1;
    for (int i = 0; i < hand.size(); i++) {
        int val = getCardValue(hand[i]);
        if (val >= highestValue and val < lowestBeatingValue) {
            lowestBeatingValue = val;
            lowestBeatingIndex = i;
        }
    }
    return lowestBeatingIndex;
}

bool canPlayerBeat (vector<int>& hand, int highestValue) { //checks if player has a card that can beat the highest
    int beatingIndex = findLowestBeating(hand, highestValue);
    return (beatingIndex != -1);
}

int countActivePlayers (bool active[]) { //counts how many players are still active
    int count = 0;
    for (int i = 0; i < 3; i++) {
        if (active[i]) {
            count++;
        }
    }
    return count;
}
