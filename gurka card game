int calculatePenalty (int cardPlayed, int highestValue) { //calculates penalty points for a card
    int cardValue = getCardValue(cardPlayed);
    if (cardValue == highestValue) {
        return cardValue;
    } else {
        return 0;
    }
}

int findHighestCardValue (int cardsPlayed[]) { //finds the highest card value from cards played
    int highest = -1;
    for (int i = 0; i < 3; i++) {
        if (cardsPlayed[i] != -1) {
            int val = getCardValue(cardsPlayed[i]);
            if (val > highest) {
                highest = val;
            }
        }
    }
    return highest;
}

